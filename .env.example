# ── Verplicht ────────────────────────────────────────────────────────────────
# Groq API key — gratis aanmaken op https://console.groq.com
GROQ_API_KEY=gsk_...

# ── Aanbevolen ───────────────────────────────────────────────────────────────
# HuggingFace token — gratis aanmaken op https://huggingface.co/settings/tokens
# Geeft toegang tot de HF Inference API (playground) + hogere rate limits op de Hub API
# Kies een token met "Read" scope (geen schrijfrechten nodig)
HUGGINGFACE_TOKEN=hf_...

# ── Optioneel ────────────────────────────────────────────────────────────────
# Supabase — voor opslaan van scenario's en feedback
VITE_SUPABASE_URL=https://jouwproject.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
